{
  "name": "registry",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.6",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome format --fix .",
    "codegen": "graphql-codegen --project storefront && bun run scripts/patch-codegen.ts",
    "lint:registry": "bun run scripts/lint-registry.ts",
